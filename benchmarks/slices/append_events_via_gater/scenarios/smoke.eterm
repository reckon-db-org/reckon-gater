%% Smoke: harness validation only. Mirrors reckon-db's smoke.eterm
%% so a paired run produces comparable cadence.
#{
    store_id            => bench_store,
    event_size_bytes    => 256,
    parallelism         => 1,
    duration_seconds    => 5,
    warmup_min_seconds  => 3,
    warmup_min_ops      => 500,
    warmup_max_seconds  => 60,
    measure_min_ops     => 500,
    measure_max_seconds => 30,
    tags                => [smoke, validation]
}.
