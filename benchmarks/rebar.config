{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {reckon_db,            "~> 1.7"},
    {reckon_gater,         "~> 1.3"},
    {reckon_bench_harness, "~> 0.1"}
]}.

{profiles, [
    {bench, [
        {erl_opts, [debug_info]},
        {extra_src_dirs, ["slices"]},
        {src_dirs, ["slices"]}
    ]}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [reckon_db, reckon_gater, reckon_bench_harness]}
]}.
